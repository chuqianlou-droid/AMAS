笛卡尔坐标映射
终端 1：Gazebo
source /opt/ros/humble/setup.bash
source ~/dobot_ws/install/setup.bash
export DOBOT_TYPE=cr5

ros2 launch dobot_gazebo dobot_gazebo.launch.py
终端 2：控制器
source /opt/ros/humble/setup.bash
source ~/dobot_ws/install/setup.bash
export DOBOT_TYPE=cr5

ros2 run controller_manager spawner joint_state_broadcaster --controller-manager /controller_manager
ros2 run controller_manager spawner cr5_group_controller --controller-manager /controller_manager
终端 3：MoveIt
source /opt/ros/humble/setup.bash
source ~/dobot_ws/install/setup.bash
export DOBOT_TYPE=cr5

#发送初始位姿
ros2 topic pub --once /cr5_group_controller/joint_trajectory trajectory_msgs/msg/JointTrajectory "
joint_names: [joint1, joint2, joint3, joint4, joint5, joint6]
points:
- positions: [-1.6070644255285222, 0.18769253305020653, -2.2449121352204386, 1.7398662799713305, 1.6257743302896626, -0.025289968168858954]
  time_from_start:
    sec: 2
    nanosec: 0
"

ros2 launch cr5_moveit move_group.launch.py
